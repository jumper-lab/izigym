# Copie este arquivo para .env e preencha os valores locais.
# Nunca commite .env.

# Token Basic auth da API EVO/W12 usado pelo frontend Vite.
VITE_API_AUTH_TOKEN=

# Em desenvolvimento passa pelo proxy do vite.config.ts.
# Em producao passa pelo rewrite/proxy configurado no deploy.
VITE_API_BASE_URL=/api-evo/api/v2
